---
const navLinks = [
  { href: '/how-it-works', label: 'How it works' },
  { href: '/pricing',      label: 'Pricing' },
  { href: '/professionals', label: 'For Professionals' },
];
---

<header class="nav-wrapper">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Heirly — home">Heirly</a>

    <button
      class="nav-hamburger"
      id="nav-toggle"
      aria-controls="nav-menu"
      aria-expanded="false"
      aria-label="Open navigation menu"
    >
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

    <nav id="nav-menu" class="nav-menu" aria-label="Main navigation">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
      <a
        href="https://app.heirly.app"
        class="nav-cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        Get started
      </a>
    </nav>
  </div>
</header>

<style>
  .nav-wrapper {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--color-cream);
    border-bottom: 1px solid rgba(45, 74, 62, 0.12);
  }

  .nav-inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 68px;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-forest);
    text-decoration: none;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex: 1;
    justify-content: flex-end;
  }

  .nav-link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-slate);
    text-decoration: none;
    transition: color 0.15s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--color-forest);
  }

  .nav-cta {
    background-color: var(--color-gold);
    color: var(--color-forest);
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 0.5rem 1.125rem;
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.15s ease;
  }

  .nav-cta:hover {
    opacity: 0.88;
  }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    margin-left: auto;
    border-radius: 4px;
  }

  .bar {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-forest);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .nav-hamburger[aria-expanded="true"] .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-hamburger[aria-expanded="true"] .bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-hamburger[aria-expanded="true"] .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .nav-hamburger {
      display: flex;
    }

    .nav-menu {
      display: none;
      position: absolute;
      top: 68px;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background-color: var(--color-cream);
      border-bottom: 1px solid rgba(45, 74, 62, 0.12);
      padding: 0.25rem 1.5rem 1.25rem;
    }

    .nav-menu.is-open {
      display: flex;
    }

    .nav-link {
      padding: 0.875rem 0;
      border-bottom: 1px solid rgba(45, 74, 62, 0.08);
      font-size: 1rem;
    }

    .nav-cta {
      margin-top: 1rem;
      text-align: center;
      padding: 0.75rem 1.25rem;
      font-size: 1rem;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu   = document.getElementById('nav-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(!!isOpen));
  });

  // Close on link click (mobile)
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
