---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">Heirly</span>
      <p class="footer-tagline">Helping families through what matters most. Serving the UK, Australia &amp; New Zealand.</p>
    </div>

    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/how-it-works">How it works</a>
      <a href="/pricing">Pricing</a>
      <a href="/professionals">For Professionals</a>
      <a href="mailto:hello@heirly.app">Contact</a>
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms</a>
    </nav>
  </div>

  <div class="footer-bottom">
    <p>&copy; {year} Heirly. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-forest);
    color: var(--color-cream);
    padding: 3.5rem 1.5rem 1.5rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2.5rem;
    flex-wrap: wrap;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(245, 240, 232, 0.15);
  }

  .footer-logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.375rem;
    color: var(--color-cream);
    display: block;
    margin-bottom: 0.5rem;
  }

  .footer-tagline {
    margin: 0;
    font-size: 0.875rem;
    color: rgba(245, 240, 232, 0.55);
    max-width: 36ch;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem 1.75rem;
    align-items: center;
  }

  .footer-links a {
    color: rgba(245, 240, 232, 0.7);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.15s ease;
  }

  .footer-links a:hover {
    color: var(--color-cream);
  }

  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 1.25rem;
  }

  .footer-bottom p {
    margin: 0;
    font-size: 0.8125rem;
    color: rgba(245, 240, 232, 0.35);
  }
</style>
