---
import Layout from '../layouts/Layout.astro';

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Heirly",
  "foundingDate": "2026",
  "url": "https://heirly.app",
  "logo": "https://heirly.app/og/og-home.png",
  "description": "Heirly is estate settlement software that helps executors and families catalogue belongings, run structured allocation rounds, and reach a fair, transparent settlement after a death. Serves the UK, Australia, and New Zealand.",
  "email": "hello@heirly.app",
  "areaServed": ["GB", "AU", "NZ"],
  "availableLanguage": "English",
  "sameAs": [],
  "knowsAbout": [
    "Estate settlement",
    "Probate administration",
    "Estate allocation",
    "Executor responsibilities",
    "Family mediation",
    "Inheritance distribution"
  ]
};
---

<Layout
  title="About Heirly — Estate Settlement Software"
  description="Heirly is estate settlement software founded in 2026, helping executors and families in the UK, Australia, and New Zealand divide belongings fairly after a loss."
  ogImage="/og/og-home.png"
>
  <Fragment slot="head">
    <!-- PLACEHOLDER: add LinkedIn, Crunchbase, Companies House URL when available -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="about-hero">
    <div class="container">
      <p class="eyebrow">About</p>
      <h1>Built for one of life's hardest moments</h1>
    </div>
  </section>

  <!-- Entity paragraph -->
  <section class="about-section bg-cream">
    <div class="container">
      <p class="entity-para">Heirly is estate settlement software founded in 2026. It helps executors and families in the UK, Australia, and New Zealand catalogue a deceased person's belongings, invite family members to participate, run structured allocation rounds, and produce a transparent settlement ledger. The system is designed to reduce family conflict, remove spreadsheet administration, and give every participant a clear, documented record of how decisions were made.</p>
    </div>
  </section>

  <!-- Why we built it -->
  <section class="about-section bg-tint">
    <div class="container">
      <h2>Why we built it</h2>
      <p>Dividing personal belongings after a death is one of the least-discussed parts of estate administration — and one of the most common sources of lasting family conflict. Solicitors see it regularly. Funeral directors hear about it. Families live through it. Yet there was no structured, neutral tool designed for it.</p>
      <p>Heirly is that tool. It separates sentimental allocation from financial fairness, resolves uncontested items automatically, and gives every family member the same transparent view of how the estate was divided. The executor stays in control. The process stays dignified.</p>
    </div>
  </section>

  <!-- What Heirly is and isn't -->
  <section class="about-section bg-cream about-isnt">
    <div class="container-wide">
      <h2 class="centered">What Heirly is — and isn't</h2>
      <div class="is-isnt-grid">
        <div>
          <p class="col-heading col-heading--is">What Heirly is</p>
          <ul class="check-list">
            <li>Estate settlement software for executors</li>
            <li>A structured allocation system for families</li>
            <li>A tool for sentimental and financial fairness</li>
            <li>A full audit trail and settlement ledger</li>
            <li>Available free for estates up to 10 items</li>
          </ul>
        </div>
        <div>
          <p class="col-heading col-heading--isnt">What Heirly is not</p>
          <ul class="cross-list">
            <li>An auction or bidding platform</li>
            <li>A probate legal service</li>
            <li>A marketplace for selling estate items</li>
            <li>A subscription product</li>
            <li>A replacement for legal advice</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Who uses Heirly -->
  <section class="about-section bg-tint">
    <div class="container">
      <h2>Who uses Heirly</h2>
      <p>Executors — often a family member taking on the role for the first time — use Heirly to manage the distribution of belongings without chasing people, mediating arguments, or building spreadsheets. It gives them a structured process and a defensible record.</p>
      <p>Family members and beneficiaries participate via a simple email invitation. No account creation, no password. They express their preferences at their own pace and can always see how items were allocated and why.</p>
      <p>Probate solicitors, funeral directors, and estate agents refer clients to Heirly as part of their service offering. It reduces the family disputes that land back on professional desks and adds a meaningful layer to aftercare and estate administration services.</p>
    </div>
  </section>

  <!-- Where we operate -->
  <section class="about-section bg-cream">
    <div class="container">
      <h2>Where we operate</h2>
      <p>Heirly is available to families and professionals in the United Kingdom, Australia, and New Zealand. The platform is in English. Get in touch at <a href="mailto:hello@heirly.app" class="inline-link">hello@heirly.app</a>.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="about-cta">
    <div class="container">
      <div class="cta-actions">
        <a href="https://app.heirly.app" class="btn-primary" target="_blank" rel="noopener noreferrer">Start your estate free</a>
        <a href="/professionals" class="btn-secondary">Partner with us →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .container-wide {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero */
  .about-hero {
    background: var(--color-forest);
    color: var(--color-cream);
    padding: 5rem 1.5rem 4rem;
    text-align: center;
  }
  .about-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-cream);
    margin: 0;
    line-height: 1.15;
  }
  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 1rem;
  }

  /* Sections */
  .about-section {
    padding: 4.5rem 1.5rem;
  }
  .bg-cream { background: var(--color-cream); }
  .bg-tint { background: var(--color-tint); }

  .about-section h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    color: var(--color-forest);
    margin: 0 0 1.5rem;
  }
  .about-section p {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-slate);
    margin: 0 0 1.25rem;
  }
  .about-section p:last-child { margin-bottom: 0; }

  .entity-para {
    font-size: 1.125rem;
    line-height: 1.8;
  }

  /* Is / isn't */
  .about-isnt { padding: 4.5rem 1.5rem; }
  .centered {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .is-isnt-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }
  .col-heading {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 1.25rem;
  }
  .col-heading--is { color: var(--color-sage); }
  .col-heading--isnt { color: #8B2635; }

  .check-list,
  .cross-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .check-list li,
  .cross-list li {
    padding: 0.75rem 0 0.75rem 2rem;
    position: relative;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    font-size: 1rem;
    color: var(--color-slate);
    line-height: 1.5;
  }
  .check-list li:last-child,
  .cross-list li:last-child {
    border-bottom: none;
  }
  .check-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-sage);
    font-weight: 700;
  }
  .cross-list li::before {
    content: '✗';
    position: absolute;
    left: 0;
    color: #8B2635;
    font-weight: 700;
  }

  /* Inline link */
  .inline-link {
    color: var(--color-forest);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .inline-link:hover { opacity: 0.75; }

  /* CTA section */
  .about-cta {
    background: var(--color-forest);
    padding: 4rem 1.5rem;
    text-align: center;
  }
  .cta-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-block;
    background: var(--color-gold);
    color: var(--color-forest);
    padding: 0.875rem 2rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: opacity 0.15s ease;
  }
  .btn-primary:hover { opacity: 0.9; }
  .btn-secondary {
    display: inline-block;
    color: var(--color-cream);
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    border-bottom: 1px solid rgba(245, 240, 232, 0.4);
    padding-bottom: 2px;
    transition: border-color 0.15s ease;
  }
  .btn-secondary:hover { border-color: var(--color-cream); }

  @media (max-width: 640px) {
    .is-isnt-grid { grid-template-columns: 1fr; gap: 2rem; }
    .about-section,
    .about-isnt { padding: 3rem 1.5rem; }
    .about-cta { padding: 3rem 1.5rem; }
  }
</style>
