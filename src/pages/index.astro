---
import Layout from '../layouts/Layout.astro';
import StepCard from '../components/StepCard.astro';
import ValuePropCard from '../components/ValuePropCard.astro';
import PricingCard from '../components/PricingCard.astro';

const steps = [
  {
    number: 1,
    title: 'Catalogue',
    description:
      'The executor adds items to the estate. Upload a photo and our AI suggests a title and estimated value — no specialist knowledge required.',
  },
  {
    number: 2,
    title: 'Preferences',
    description:
      'Family members are invited by email and express what matters to them through guided allocation rounds. No competition. No anxiety.',
  },
  {
    number: 3,
    title: 'Settlement',
    description:
      'Items are fairly distributed and recorded in a clear, transparent ledger that every family member can see. Nothing hidden, nothing disputed.',
  },
];

const valueProps = [
  {
    icon: '✦',
    title: 'Most items resolve automatically',
    description:
      'When only one person wants something, it\'s theirs — no discussion needed. Heirly only surfaces the items that genuinely need a conversation.',
  },
  {
    icon: '⚖',
    title: 'Sentimental and financial fairness are separate',
    description:
      'A photograph of a parent has no market value but infinite personal meaning. Heirly handles sentimental and financial items through different processes.',
  },
  {
    icon: '◎',
    title: 'Full transparency',
    description:
      'Every allocation is visible to every family member. No backroom decisions. No one wonders whether they were treated fairly.',
  },
  {
    icon: '❖',
    title: 'Executor in control',
    description:
      'The executor sets the pace, opens and closes rounds, and has the final say. Heirly gives them the tools to run the process calmly.',
  },
];

const freePlanFeatures = [
  'Up to 10 items',
  'Sentimental allocation rounds',
  'Family invitation by email',
  'Transparent allocation ledger',
];

const paidPlanFeatures = [
  'Unlimited items',
  'Financial allocation rounds',
  'Settlement calculator',
  'Full PDF report & audit export',
  'Priority support',
];
---

<Layout
  title="A fair way to divide what matters most"
  description="Heirly helps families divide belongings transparently and fairly after a loss — reducing conflict, preserving relationships."
>

  <!-- ——— Hero ——— -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1 class="hero-headline">
          A fair way to divide<br />what matters most
        </h1>
        <p class="hero-subhead">
          Heirly helps families divide belongings transparently and fairly after a loss —
          reducing conflict, preserving relationships.
        </p>
        <div class="hero-actions">
          <a
            href="https://app.heirly.app"
            class="btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Start your estate
          </a>
          <a href="#how-it-works" class="btn-ghost">See how it works</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ——— How it works ——— -->
  <section id="how-it-works" class="section-pad bg-cream">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">How Heirly works</h2>
        <p class="section-subtitle">
          Three steps to a fair, transparent settlement — guided throughout.
        </p>
      </div>
      <div class="steps-row">
        {steps.map(step => (
          <StepCard number={step.number} title={step.title} description={step.description} />
        ))}
      </div>
      <p class="steps-link">
        <a href="/how-it-works" class="link-arrow">Read the full walkthrough →</a>
      </p>
    </div>
  </section>

  <!-- ——— Why Heirly ——— -->
  <section class="section-pad bg-tint">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Designed for difficult moments</h2>
        <p class="section-subtitle">
          Every feature exists to reduce stress, not add to it.
        </p>
      </div>
      <div class="vp-grid">
        {valueProps.map(vp => (
          <ValuePropCard title={vp.title} description={vp.description} icon={vp.icon} />
        ))}
      </div>
    </div>
  </section>

  <!-- ——— Who it's for ——— -->
  <section class="section-pad bg-forest">
    <div class="container">
      <div class="section-header-light">
        <h2 class="section-title-light">Who Heirly is for</h2>
      </div>
      <div class="who-grid">
        <div class="who-card">
          <h3 class="who-title">Executors</h3>
          <p class="who-desc">
            You have enough on your plate. Heirly gives you a structured, respectful way to manage
            the distribution of belongings — without chasing people, managing spreadsheets, or
            mediating arguments. Invite the family, open a round when you're ready, and let the
            process do the heavy lifting.
          </p>
        </div>
        <div class="who-divider" aria-hidden="true"></div>
        <div class="who-card">
          <h3 class="who-title">Family members</h3>
          <p class="who-desc">
            You receive a simple email invitation — no account to create, no password to remember.
            See what's in the estate, share your preferences at your own pace, and always know how
            items were allocated and why. Nothing happens without your knowledge.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ——— Pricing ——— -->
  <section id="pricing" class="section-pad bg-cream">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Simple, fair pricing</h2>
        <p class="section-subtitle">One estate. One payment. No subscription.</p>
      </div>
      <div class="pricing-row">
        <PricingCard
          plan="Free"
          price="£0"
          priceNote="Forever free"
          features={freePlanFeatures}
          cta="Start free"
          ctaHref="https://app.heirly.app"
        />
        <PricingCard
          plan="Full estate"
          price="£99"
          priceNote="One-time per estate"
          features={paidPlanFeatures}
          cta="Get started"
          ctaHref="https://app.heirly.app"
          highlighted={true}
          badge="Most estates"
        />
      </div>
      <p class="pricing-footnote">
        <a href="/pricing" class="link-arrow">See full pricing details and FAQs →</a>
      </p>
    </div>
  </section>

  <!-- ——— For professionals ——— -->
  <section class="professionals-band">
    <div class="container">
      <div class="professionals-inner">
        <p class="professionals-label">For professionals</p>
        <h2 class="professionals-heading">
          Supporting probate professionals<br />and estate services
        </h2>
        <p class="professionals-desc">
          Probate lawyers, funeral homes, and estate agents use Heirly to provide a dignified,
          transparent process for their clients. Ask us about our referral channel.
        </p>
        <a
          href="/professionals"
          class="btn-primary"
        >
          Partner with Heirly
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ——— Shared layout ——— */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-pad { padding: 5.5rem 0; }

  .bg-cream  { background-color: var(--color-cream); }
  .bg-tint   { background-color: var(--color-tint); }
  .bg-forest { background-color: var(--color-forest); }

  /* ——— Section headers ——— */
  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-slate);
    margin: 0 0 0.75rem;
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--color-slate);
    opacity: 0.68;
    margin: 0 auto;
    max-width: 50ch;
  }

  .section-header-light {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title-light {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-cream);
    margin: 0;
  }

  /* ——— Hero ——— */
  .hero {
    background-color: var(--color-forest);
    padding: 7rem 0 6rem;
  }

  .hero-content {
    max-width: 680px;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--color-cream);
    line-height: 1.15;
    margin: 0 0 1.5rem;
  }

  .hero-subhead {
    font-size: 1.1875rem;
    line-height: 1.75;
    color: rgba(245, 240, 232, 0.8);
    margin: 0 0 2.5rem;
    max-width: 52ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  /* ——— Buttons ——— */
  .btn-primary {
    display: inline-block;
    background-color: var(--color-gold);
    color: var(--color-forest);
    font-weight: 600;
    font-size: 1rem;
    padding: 0.875rem 1.75rem;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .btn-primary:hover { opacity: 0.88; }

  .btn-ghost {
    display: inline-block;
    color: var(--color-cream);
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid rgba(245, 240, 232, 0.45);
    transition: border-color 0.15s ease;
  }

  .btn-ghost:hover { border-color: var(--color-cream); }

  /* ——— Steps ——— */
  .steps-row {
    display: flex;
    gap: 0;
    position: relative;
  }

  .steps-row::after {
    content: '';
    position: absolute;
    top: 23px;
    left: calc(1.75rem + 46px / 2);
    right: calc(1.75rem + 46px / 2);
    height: 1px;
    background: linear-gradient(
      to right,
      rgba(212, 175, 55, 0.5),
      rgba(212, 175, 55, 0.15)
    );
    pointer-events: none;
  }

  .steps-link {
    text-align: center;
    margin: 2.5rem 0 0;
  }

  /* ——— Value props ——— */
  .vp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  /* ——— Who it's for ——— */
  .who-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 3rem;
    align-items: start;
    max-width: 900px;
    margin: 0 auto;
  }

  .who-divider {
    width: 1px;
    min-height: 180px;
    background-color: rgba(245, 240, 232, 0.18);
  }

  .who-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    color: var(--color-cream);
    margin: 0 0 1rem;
  }

  .who-desc {
    font-size: 1rem;
    line-height: 1.78;
    color: rgba(245, 240, 232, 0.72);
    margin: 0;
  }

  /* ——— Pricing ——— */
  .pricing-row {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    align-items: flex-start;
  }

  .pricing-footnote {
    text-align: center;
    margin: 2rem 0 0;
  }

  /* ——— Professionals band ——— */
  .professionals-band {
    background-color: var(--color-sage);
    padding: 5.5rem 0;
  }

  .professionals-inner {
    max-width: 640px;
  }

  .professionals-label {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-gold);
    margin: 0 0 0.875rem;
  }

  .professionals-heading {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3vw, 2.375rem);
    color: var(--color-cream);
    margin: 0 0 1.25rem;
    line-height: 1.2;
  }

  .professionals-desc {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: rgba(245, 240, 232, 0.8);
    margin: 0 0 2rem;
    max-width: 52ch;
  }

  /* ——— Links ——— */
  .link-arrow {
    color: var(--color-sage);
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .link-arrow:hover { color: var(--color-forest); }

  /* ——— Responsive ——— */
  @media (max-width: 768px) {
    .section-pad { padding: 4rem 0; }
    .hero { padding: 5rem 0 4rem; }

    .steps-row {
      flex-direction: column;
    }

    .steps-row::after { display: none; }

    .who-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .who-divider { display: none; }

    .pricing-row {
      flex-direction: column;
      align-items: center;
    }

    .professionals-band { padding: 4rem 0; }
  }
</style>
