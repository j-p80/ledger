---
import Layout from '../layouts/Layout.astro';
import StepCard from '../components/StepCard.astro';
import ValuePropCard from '../components/ValuePropCard.astro';
import PricingCard from '../components/PricingCard.astro';

const steps = [
  {
    number: 1,
    title: 'Catalogue',
    description:
      'The executor adds items to the estate. Upload a photo and our AI suggests a title and estimated value — no specialist knowledge required.',
  },
  {
    number: 2,
    title: 'Preferences',
    description:
      'Family members are invited by email and express what matters to them through guided allocation rounds. No competition. No anxiety.',
  },
  {
    number: 3,
    title: 'Settlement',
    description:
      'Items are fairly distributed and recorded in a clear, transparent ledger that every family member can see. Nothing hidden, nothing disputed.',
  },
];

const valueProps = [
  {
    icon: '✦',
    title: 'Most items resolve automatically',
    description:
      "When only one person wants something, it's theirs — no discussion needed. Heirly only surfaces the items that genuinely need a conversation.",
  },
  {
    icon: '⚖',
    title: 'Sentimental and financial fairness are separate',
    description:
      'A photograph of a parent has no market value but infinite personal meaning. Heirly handles sentimental and financial items through different processes.',
  },
  {
    icon: '◎',
    title: 'Full transparency',
    description:
      'Every allocation is visible to every family member. No backroom decisions. No one wonders whether they were treated fairly.',
  },
  {
    icon: '❖',
    title: 'Executor in control',
    description:
      'The executor sets the pace, opens and closes rounds, and has the final say. Heirly gives them the tools to run the process calmly.',
  },
];

const freePlanFeatures = [
  'Up to 10 items',
  'Sentimental allocation rounds',
  'Family invitation by email',
  'Transparent allocation ledger',
];

const paidPlanFeatures = [
  'Unlimited items',
  'Financial allocation rounds',
  'Settlement calculator',
  'Full PDF report & audit export',
  'Priority support',
];
---

<Layout
  title="A structured way to divide what matters most"
  description="Heirly helps executors catalogue an estate, invite family members, and reach a fair allocation of belongings — with full transparency and no family conflict."
>

  <!-- ——— Hero ——— -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">

        <!-- Left: text -->
        <div class="hero-text">
          <p class="eyebrow">Estate settlement, simplified</p>
          <h1 class="hero-h1">A structured way to divide what matters most</h1>
          <p class="hero-sub">
            Heirly helps executors catalogue an estate, invite family members, and reach a fair
            allocation of belongings — with full transparency and no family conflict.
          </p>
          <div class="hero-actions">
            <a
              href="https://app.heirly.app"
              class="btn-dark"
              target="_blank"
              rel="noopener noreferrer"
            >
              Start your estate — it's free
            </a>
            <a href="/how-it-works" class="btn-text-link">See how it works →</a>
          </div>
          <p class="trust-bar">
            <span>No credit card required</span>
            <span class="trust-dot" aria-hidden="true">·</span>
            <span>Takes 10 minutes to set up</span>
            <span class="trust-dot" aria-hidden="true">·</span>
            <span>Free for up to 10 items</span>
          </p>
        </div>

        <!-- Right: product mockup -->
        <div class="hero-visual">
          <!-- PLACEHOLDER: replace with real product screenshot when available -->
          <div class="mockup-wrap">
            <div class="mockup-card" aria-hidden="true">
              <div class="mockup-top-bar">
                <span class="mockup-dot red"></span>
                <span class="mockup-dot amber"></span>
                <span class="mockup-dot green"></span>
                <span class="mockup-estate-label">Henderson Estate</span>
              </div>
              <div class="mockup-body">
                <div class="mockup-item-card">
                  <div class="mockup-item-header">
                    <div>
                      <div class="mockup-item-title">Oak Writing Desk</div>
                      <div class="mockup-item-id">#ITEM-0012</div>
                    </div>
                    <span class="badge-resolved">Auto-resolved</span>
                  </div>
                  <div class="mockup-prefs-row">
                    <div class="mockup-avatars">
                      <div class="avatar avatar-s">S</div>
                      <div class="avatar avatar-m">M</div>
                    </div>
                    <span class="prefs-label">Preferences submitted</span>
                  </div>
                </div>
                <div class="mockup-item-card mockup-item-card--dim">
                  <div class="mockup-item-header">
                    <div>
                      <div class="mockup-item-title">Watercolour Print</div>
                      <div class="mockup-item-id">#ITEM-0013</div>
                    </div>
                    <span class="badge-pending">Awaiting input</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <p class="mockup-caption">Illustrative — actual UI may vary</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ——— Stats bar ——— -->
  <!-- PLACEHOLDER: update stats when real data is available -->
  <section class="stats-band">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-number">500+</span>
          <span class="stat-label">families guided</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">92%</span>
          <span class="stat-label">of items allocated without dispute</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">UK &amp; AU</span>
          <span class="stat-label">Used by probate professionals</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ——— How it works ——— -->
  <section id="how-it-works" class="section-pad bg-cream">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">How Heirly works</h2>
        <p class="section-subtitle">Three steps to a fair, transparent settlement — guided throughout.</p>
      </div>
      <div class="steps-row">
        {steps.map(step => (
          <StepCard number={step.number} title={step.title} description={step.description} />
        ))}
      </div>
      <p class="steps-link">
        <a href="/how-it-works" class="link-arrow">Read the full walkthrough →</a>
      </p>
    </div>
  </section>

  <!-- ——— Why Heirly ——— -->
  <section class="section-pad bg-tint">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Designed for difficult moments</h2>
        <p class="section-subtitle">Every feature exists to reduce stress, not add to it.</p>
      </div>
      <div class="vp-grid">
        {valueProps.map(vp => (
          <ValuePropCard title={vp.title} description={vp.description} icon={vp.icon} />
        ))}
      </div>
    </div>
  </section>

  <!-- ——— Testimonials ——— -->
  <!-- PLACEHOLDER: replace with verified testimonials when available -->
  <section class="testimonials-section">
    <div class="container">
      <h2 class="testimonials-heading">What families say</h2>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <p class="testimonial-quote">
            "I was dreading having to manage my mother's estate with my siblings. Heirly made
            it feel manageable — everyone could see exactly how decisions were made."
          </p>
          <div class="testimonial-attr">
            <span class="testimonial-name">Sarah T., Executor · London</span>
            <span class="testimonial-estate">Henderson Estate, 2026</span>
          </div>
        </div>
        <div class="testimonial-card">
          <p class="testimonial-quote">
            "We've always struggled to talk about this stuff as a family. Having a neutral
            system meant we focused on what mattered — not on arguing."
          </p>
          <div class="testimonial-attr">
            <span class="testimonial-name">Mark R., Beneficiary · Sydney</span>
            <span class="testimonial-estate">Pemberton Estate, 2026</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ——— Who it's for ——— -->
  <section class="section-pad bg-forest">
    <div class="container">
      <div class="section-header-light">
        <h2 class="section-title-light">Who Heirly is for</h2>
      </div>
      <div class="who-grid">
        <div class="who-card">
          <h3 class="who-title">Executors</h3>
          <p class="who-desc">
            You have enough on your plate. Heirly gives you a structured, respectful way to manage
            the distribution of belongings — without chasing people, managing spreadsheets, or
            mediating arguments. Invite the family, open a round when you're ready, and let the
            process do the heavy lifting.
          </p>
        </div>
        <div class="who-divider" aria-hidden="true"></div>
        <div class="who-card">
          <h3 class="who-title">Family members</h3>
          <p class="who-desc">
            You receive a simple email invitation — no account to create, no password to remember.
            See what's in the estate, share your preferences at your own pace, and always know how
            items were allocated and why. Nothing happens without your knowledge.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ——— Pricing ——— -->
  <section id="pricing" class="section-pad bg-cream">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Simple, fair pricing</h2>
        <p class="section-subtitle">One estate. One payment. No subscription.</p>
      </div>
      <div class="pricing-row">
        <PricingCard
          plan="Free"
          price="£0"
          priceNote="Forever free"
          features={freePlanFeatures}
          cta="Start free"
          ctaHref="https://app.heirly.app"
        />
        <PricingCard
          plan="Full estate"
          price="£99"
          priceNote="One-time per estate"
          features={paidPlanFeatures}
          cta="Get started"
          ctaHref="https://app.heirly.app"
          highlighted={true}
          badge="Most estates"
        />
      </div>
      <p class="pricing-footnote">
        <a href="/pricing" class="link-arrow">See full pricing details and FAQs →</a>
      </p>
    </div>
  </section>

  <!-- ——— For professionals ——— -->
  <section class="pros-section">
    <div class="container">
      <div class="pros-grid">

        <!-- Left: text -->
        <div class="pros-left">
          <p class="eyebrow eyebrow--sage">For professionals</p>
          <h2 class="pros-h2">A tool your clients will thank you for recommending</h2>
          <p class="pros-body">
            Probate solicitors, funeral directors, and estate agents use Heirly to offer
            families a structured, dignified process at the hardest moment. It reduces the
            family disputes that land back on your desk — and shows you care about what
            comes after the paperwork.
          </p>
          <a href="/professionals" class="btn-outlined">
            Learn about our partner programme →
          </a>
        </div>

        <!-- Right: benefit chips -->
        <div class="pros-right">
          <div class="benefit-chip">
            <span class="chip-icon" aria-hidden="true">🔗</span>
            <div class="chip-content">
              <strong class="chip-title">Dedicated referral link</strong>
              <p class="chip-desc">Your own link to share with clients. Tracks referrals back to your practice.</p>
            </div>
          </div>
          <div class="benefit-chip">
            <span class="chip-icon" aria-hidden="true">📄</span>
            <div class="chip-content">
              <strong class="chip-title">Client-ready materials</strong>
              <p class="chip-desc">We provide a one-page explainer you can include in client packs or leave in your waiting room.</p>
            </div>
          </div>
          <div class="benefit-chip">
            <span class="chip-icon" aria-hidden="true">💬</span>
            <div class="chip-content">
              <strong class="chip-title">No ongoing admin</strong>
              <p class="chip-desc">You make the introduction. We handle everything else.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  /* ——— Layout ——— */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-pad { padding: 5.5rem 0; }

  .bg-cream  { background-color: var(--color-cream); }
  .bg-tint   { background-color: var(--color-tint); }
  .bg-forest { background-color: var(--color-forest); }

  /* ——— Section headers ——— */
  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-slate);
    margin: 0 0 0.75rem;
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--color-slate);
    opacity: 0.68;
    margin: 0 auto;
    max-width: 50ch;
  }

  .section-header-light { text-align: center; margin-bottom: 3rem; }

  .section-title-light {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-cream);
    margin: 0;
  }

  /* ——— Eyebrow ——— */
  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-sage);
    margin: 0 0 1rem;
    font-family: var(--font-body);
  }

  .eyebrow--sage { color: var(--color-sage); }

  /* ——— Hero ——— */
  .hero {
    background-color: var(--color-cream);
    padding: 6rem 0 5rem;
    border-bottom: 1px solid rgba(45, 74, 62, 0.08);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3.25rem);
    color: var(--color-slate);
    line-height: 1.15;
    margin: 0 0 1.25rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--color-slate);
    opacity: 0.7;
    margin: 0 0 2rem;
    max-width: 48ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  /* ——— Buttons ——— */
  .btn-dark {
    display: inline-block;
    background-color: var(--color-forest);
    color: var(--color-cream);
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 0.875rem 1.625rem;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }

  .btn-dark:hover { opacity: 0.88; }

  .btn-text-link {
    display: inline-block;
    color: var(--color-slate);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: rgba(44, 62, 80, 0.35);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s ease;
  }

  .btn-text-link:hover { text-decoration-color: var(--color-slate); }

  .btn-outlined {
    display: inline-block;
    border: 2px solid var(--color-forest);
    color: var(--color-forest);
    background-color: var(--color-cream);
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .btn-outlined:hover {
    background-color: var(--color-forest);
    color: var(--color-cream);
  }

  /* ——— Trust bar ——— */
  .trust-bar {
    font-size: 0.8125rem;
    color: var(--color-slate);
    opacity: 0.52;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    align-items: center;
  }

  .trust-dot { opacity: 0.6; }

  /* ——— Mockup ——— */
  .hero-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.875rem;
  }

  .mockup-wrap {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .mockup-card {
    width: 100%;
    max-width: 380px;
    background-color: #fff;
    border-radius: 14px;
    border: 1px solid rgba(45, 74, 62, 0.12);
    box-shadow:
      0 4px 6px rgba(45, 74, 62, 0.05),
      0 20px 60px rgba(45, 74, 62, 0.12);
    transform: rotate(3deg);
    overflow: hidden;
  }

  .mockup-top-bar {
    background-color: var(--color-forest);
    padding: 0.625rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .mockup-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: block;
    flex-shrink: 0;
  }

  .mockup-dot.red    { background-color: #FF5F57; }
  .mockup-dot.amber  { background-color: #FFBD2E; }
  .mockup-dot.green  { background-color: #28C840; }

  .mockup-estate-label {
    margin-left: 0.5rem;
    font-size: 0.75rem;
    color: rgba(245, 240, 232, 0.7);
    font-family: var(--font-body);
  }

  .mockup-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    background-color: var(--color-tint);
  }

  .mockup-item-card {
    background-color: #fff;
    border-radius: 8px;
    padding: 0.875rem;
    border: 1px solid rgba(45, 74, 62, 0.1);
  }

  .mockup-item-card--dim { opacity: 0.55; }

  .mockup-item-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .mockup-item-title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-slate);
    font-family: var(--font-body);
  }

  .mockup-item-id {
    font-size: 0.6875rem;
    color: var(--color-slate);
    opacity: 0.45;
    font-family: var(--font-body);
    margin-top: 2px;
  }

  .badge-resolved {
    font-size: 0.6875rem;
    font-weight: 600;
    background-color: rgba(74, 124, 106, 0.12);
    color: var(--color-sage);
    padding: 0.2rem 0.5rem;
    border-radius: 100px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .badge-pending {
    font-size: 0.6875rem;
    font-weight: 600;
    background-color: rgba(212, 175, 55, 0.12);
    color: #B8960A;
    padding: 0.2rem 0.5rem;
    border-radius: 100px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .mockup-prefs-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .mockup-avatars {
    display: flex;
    gap: -4px;
  }

  .avatar {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    font-size: 0.625rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #fff;
    font-family: var(--font-body);
  }

  .avatar-s { background-color: var(--color-sage); color: #fff; }
  .avatar-m { background-color: var(--color-gold); color: var(--color-forest); margin-left: -6px; }

  .prefs-label {
    font-size: 0.6875rem;
    color: var(--color-slate);
    opacity: 0.55;
    font-family: var(--font-body);
  }

  .mockup-caption {
    font-size: 0.75rem;
    color: var(--color-slate);
    opacity: 0.4;
    margin: 0;
    text-align: center;
    font-style: italic;
  }

  /* ——— Stats band ——— */
  .stats-band {
    background-color: var(--color-forest);
    padding: 3.5rem 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    color: var(--color-cream);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: rgba(245, 240, 232, 0.65);
    line-height: 1.4;
  }

  /* ——— Steps ——— */
  .steps-row {
    display: flex;
    gap: 0;
    position: relative;
  }

  .steps-row::after {
    content: '';
    position: absolute;
    top: 23px;
    left: calc(1.75rem + 46px / 2);
    right: calc(1.75rem + 46px / 2);
    height: 1px;
    background: linear-gradient(to right, rgba(212, 175, 55, 0.5), rgba(212, 175, 55, 0.15));
    pointer-events: none;
  }

  .steps-link {
    text-align: center;
    margin: 2.5rem 0 0;
  }

  /* ——— Value props ——— */
  .vp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  /* ——— Testimonials ——— */
  .testimonials-section {
    background-color: var(--color-cream);
    padding: 5.5rem 0;
  }

  .testimonials-heading {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-slate);
    text-align: center;
    margin: 0 0 3rem;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 960px;
    margin: 0 auto;
  }

  .testimonial-card {
    background-color: var(--color-cream);
    border: 1px solid #E0D8CC;
    border-radius: 12px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .testimonial-quote {
    font-size: 1.0625rem;
    line-height: 1.78;
    color: var(--color-slate);
    margin: 0;
    font-style: italic;
  }

  .testimonial-attr {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .testimonial-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-forest);
  }

  .testimonial-estate {
    font-size: 0.8125rem;
    color: var(--color-slate);
    opacity: 0.5;
  }

  /* ——— Who it's for ——— */
  .who-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 3rem;
    align-items: start;
    max-width: 900px;
    margin: 0 auto;
  }

  .who-divider {
    width: 1px;
    min-height: 180px;
    background-color: rgba(245, 240, 232, 0.18);
  }

  .who-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    color: var(--color-cream);
    margin: 0 0 1rem;
  }

  .who-desc {
    font-size: 1rem;
    line-height: 1.78;
    color: rgba(245, 240, 232, 0.72);
    margin: 0;
  }

  /* ——— Pricing ——— */
  .pricing-row {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
