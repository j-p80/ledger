---
import Layout from '../../layouts/Layout.astro';

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Estate Settlement Guides",
  "description": "Guides for executors and families on dividing belongings, estate settlement, and probate administration.",
  "url": "https://heirly.app/guides/",
  "publisher": {
    "@type": "Organization",
    "name": "Heirly",
    "url": "https://heirly.app"
  }
};

const guides = [
  {
    title: "How to divide belongings fairly after a death",
    description: "A step-by-step guide for executors on distributing personal property — what the process looks like, what tends to go wrong, and how to keep it fair.",
    href: "/guides/how-to-divide-estate-belongings/",
  },
  {
    title: "Executor responsibilities: what you're actually responsible for",
    description: "Most executors are appointed without warning. This guide explains what the role involves and what tools exist to help.",
    href: "/guides/executor-responsibilities/",
  },
  {
    title: "Sentimental vs financial items: why they need different processes",
    description: "Why treating a family photograph the same as a piece of jewellery causes conflict — and how structured allocation prevents it.",
    href: "/guides/sentimental-vs-financial-items/",
  },
  {
    title: "How to avoid family conflict when dividing an estate",
    description: "The most common sources of dispute and the practical steps that prevent them — before, during, and after allocation.",
    href: "/guides/avoiding-family-conflict-estate/",
  },
];
---

<Layout
  title="Estate Settlement Guides"
  description="Plain-language guides for executors and families — how to divide estate belongings, understand probate, and manage settlement fairly."
  ogImage="/og/og-home.png"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="guides-hero">
    <div class="container">
      <p class="eyebrow">Guides</p>
      <h1>Plain answers for executors and families</h1>
      <p class="hero-sub">Practical guidance on dividing an estate — written clearly, without legal jargon.</p>
    </div>
  </section>

  <!-- Guides grid -->
  <section class="guides-section">
    <div class="container">
      <div class="guides-grid">
        {guides.map(guide => (
          <a href={guide.href} class="guide-card">
            <h2 class="guide-card-title">{guide.title}</h2>
            <p class="guide-card-desc">{guide.description}</p>
            <span class="guide-card-link">Read guide →</span>
          </a>
        ))}
      </div>

      <p class="disclaimer">
        These guides are for general information only and do not constitute legal advice. For advice specific to your situation, consult a qualified solicitor or estate professional.
      </p>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero */
  .guides-hero {
    background: var(--color-forest);
    color: var(--color-cream);
    padding: 5rem 1.5rem 4rem;
    text-align: center;
  }
  .guides-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--color-cream);
    margin: 0 0 1rem;
    line-height: 1.2;
  }
  .hero-sub {
    color: rgba(245, 240, 232, 0.75);
    font-size: 1.125rem;
    margin: 0;
  }
  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 1rem;
  }

  /* Guides section */
  .guides-section {
    padding: 5rem 1.5rem;
    background: var(--color-cream);
  }

  /* Grid */
  .guides-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  /* Guide card */
  .guide-card {
    display: flex;
    flex-direction: column;
    background: var(--color-cream);
    border: 1px solid rgba(44, 62, 80, 0.12);
    border-radius: 12px;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .guide-card:hover {
    border-color: var(--color-sage);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }
  .guide-card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-forest);
    margin: 0 0 0.875rem;
    line-height: 1.3;
    font-weight: 700;
  }
  .guide-card-desc {
    font-size: 0.9375rem;
    color: var(--color-slate);
    line-height: 1.65;
    margin: 0 0 1.5rem;
    flex: 1;
  }
  .guide-card-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-sage);
  }

  /* Disclaimer */
  .disclaimer {
    font-size: 0.8125rem;
    color: rgba(44, 62, 80, 0.5);
    text-align: center;
    border-top: 1px solid rgba(44, 62, 80, 0.1);
    padding-top: 2rem;
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .guides-grid { grid-template-columns: 1fr; }
    .guides-section { padding: 3rem 1.5rem; }
  }
</style>
