---
import Layout from '../layouts/Layout.astro';
import PricingCard from '../components/PricingCard.astro';

const freePlanFeatures = [
  'Up to 10 items',
  'Sentimental allocation rounds',
  'Family invitation by email',
  'Transparent allocation ledger',
];

const paidPlanFeatures = [
  'Unlimited items',
  'Financial allocation rounds',
  'Settlement calculator',
  'Full PDF report & audit export',
  'Priority support',
];

const faqs = [
  {
    q: 'Is Heirly really free right now?',
    a: 'Yes. Heirly is in early access — both tiers are completely free while we work with founding estates to refine the product. Pricing will be introduced once early access closes, and all early access estates will be notified well in advance.',
  },
  {
    q: 'Is this a subscription?',
    a: 'No. Heirly charges a one-time payment per estate. There are no monthly fees, no renewals, and nothing to cancel. You pay once, for one estate, and the tools are yours for as long as you need them.',
  },
  {
    q: 'What happens when I reach the 10 item limit?',
    a: "During early access, the 10 item limit on the free tier still applies. If your estate has more than 10 items, request early access to the full tier and we'll enable it for you manually.",
  },
  {
    q: 'How does the family access the estate?',
    a: 'Family members receive a personalised email invitation with a magic link. Clicking it takes them straight into the estate — no account creation, no password. Each link is private and tied to their email address.',
  },
  {
    q: 'Is my data secure?',
    a: "Yes. Heirly is built on Supabase with row-level security, meaning each user can only see the data they're permitted to access. All documents and photos are stored in private, access-controlled storage. We take the security of sensitive family data seriously.",
  },
];
---

<Layout
  fullTitle="Heirly Pricing — Free During Early Access"
  title="Pricing"
  description="Heirly is free during early access — both tiers, no credit card required. Pricing will be introduced once early access closes. All early access estates notified in advance."
  ogImage="/og/og-home.png"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(item => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.a
        }
      }))
    })} />
  </Fragment>

  <!-- ——— Page hero ——— -->
  <section class="page-hero">
    <div class="container">
      <h1>Simple, transparent pricing</h1>
      <p class="lead">Free during early access. No credit card required.</p>
    </div>
  </section>

  <!-- ——— Pricing cards ——— -->
  <section class="pricing-section">
    <div class="container">
      <div class="pricing-row">
        <PricingCard
          plan="Free"
          price="£0"
          priceNote="Forever free"
          features={freePlanFeatures}
          cta="Start free"
          ctaHref="https://app.heirly.app"
        />
        <PricingCard
          plan="Full estate"
          price="Free"
          priceNote="during early access"
          features={paidPlanFeatures}
          cta="Request early access"
          ctaHref="mailto:hello@heirly.app?subject=Early%20Access%20Request"
          highlighted={true}
        />
      </div>
      <p class="pricing-note">Pricing will be introduced once early access closes. Early access estates will be notified in advance.</p>
    </div>
  </section>

  <!-- ——— Notify ——— -->
  <section class="notify-section">
    <div class="container">
      <h2 class="notify-heading">Not ready yet?</h2>
      <p class="notify-sub">Leave your email and we'll let you know when Heirly opens to new estates.</p>
      <form class="notify-form" id="notify-form" novalidate>
        <input
          type="email"
          name="notify_email"
          class="notify-input"
          placeholder="your@email.com"
          autocomplete="email"
          required
        />
        <button type="submit" class="notify-btn">Notify me</button>
      </form>
    </div>
  </section>

  <!-- ——— FAQ ——— -->
  <section class="faq-section">
    <div class="container">
      <h2 class="faq-heading">Frequently asked questions</h2>
      <div class="faq-list">
        {faqs.map(item => (
          <details class="faq-item">
            <summary class="faq-q">{item.q}</summary>
            <p class="faq-a">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ——— CTA ——— -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Start your estate today</h2>
      <p>No credit card required. No commitment. Just a better way to settle an estate.</p>
      <a
        href="https://app.heirly.app"
        class="btn-primary"
        target="_blank"
        rel="noopener noreferrer"
      >
        Get started free
      </a>
    </div>
  </section>

</Layout>

<style>
  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ——— Page hero ——— */
  .page-hero {
    background-color: var(--color-forest);
    padding: 5.5rem 0 4.5rem;
  }

  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.25rem);
    color: var(--color-cream);
    margin: 0 0 1rem;
  }

  .lead {
    font-size: 1.125rem;
    line-height: 1.72;
    color: rgba(245, 240, 232, 0.8);
    margin: 0;
  }

  /* ——— Pricing ——— */
  .pricing-section {
    background-color: var(--color-cream);
    padding: 5.5rem 0 3.5rem;
  }

  .pricing-row {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    align-items: flex-start;
  }

  .pricing-note {
    text-align: center;
    font-size: 0.9375rem;
    color: var(--color-slate);
    opacity: 0.55;
    font-style: italic;
    margin: 2rem 0 0;
  }

  /* ——— FAQ ——— */
  .faq-section {
    background-color: var(--color-tint);
    padding: 5rem 0;
  }

  .faq-heading {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2.125rem);
    color: var(--color-slate);
    text-align: center;
    margin: 0 0 2.75rem;
  }

  .faq-list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    background-color: #fff;
    border-radius: 10px;
    border: 1px solid rgba(45, 74, 62, 0.1);
    overflow: hidden;
  }

  .faq-q {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.375rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-slate);
    cursor: pointer;
    list-style: none;
    transition: background-color 0.15s ease;
    user-select: none;
  }

  .faq-q::-webkit-details-marker { display: none; }

  .faq-q::after {
    content: '+';
    font-size: 1.375rem;
    font-weight: 300;
    color: var(--color-sage);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  details[open] .faq-q::after {
    transform: rotate(45deg);
  }

  .faq-q:hover {
    background-color: rgba(45, 74, 62, 0.03);
  }

  .faq-a {
    font-size: 0.9375rem;
    line-height: 1.78;
    color: var(--color-slate);
    opacity: 0.78;
    padding: 0 1.375rem 1.375rem;
    margin: 0;
    border-top: 1px solid rgba(45, 74, 62, 0.07);
  }

  /* ——— CTA ——— */
  .cta-section {
    background-color: var(--color-cream);
    padding: 5.5rem 0;
  }

  .cta-inner {
    text-align: center;
  }

  .cta-inner h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-slate);
    margin: 0 0 0.875rem;
  }

  .cta-inner p {
    font-size: 1.0625rem;
    color: var(--color-slate);
    opacity: 0.62;
    margin: 0 0 2rem;
  }

  .btn-primary {
    display: inline-block;
    background-color: var(--color-gold);
    color: var(--color-forest);
    font-weight: 600;
    font-size: 1rem;
    padding: 0.875rem 1.75rem;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .btn-primary:hover { opacity: 0.88; }

  /* ——— Notify ——— */
  .notify-section {
    background-color: var(--color-cream);
    padding: 4rem 0 3rem;
    text-align: center;
  }

  .notify-heading {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.5vw, 1.875rem);
    color: var(--color-slate);
    margin: 0 0 0.625rem;
  }

  .notify-sub {
    font-size: 1rem;
    color: var(--color-slate);
    opacity: 0.62;
    margin: 0 0 1.75rem;
  }

  .notify-form {
    display: flex;
    gap: 0.625rem;
    justify-content: center;
    flex-wrap: wrap;
    max-width: 460px;
    margin: 0 auto;
  }

  .notify-input {
    flex: 1;
    min-width: 200px;
    padding: 0.75rem 1rem;
    border: 1.5px solid rgba(45, 74, 62, 0.2);
    border-radius: 7px;
    font-size: 0.9375rem;
    font-family: var(--font-body);
    color: var(--color-slate);
    background-color: #fff;
    outline: none;
    transition: border-color 0.15s ease;
  }

  .notify-input:focus {
    border-color: var(--color-sage);
  }

  .notify-btn {
    padding: 0.75rem 1.375rem;
    background-color: var(--color-sage);
    color: #fff;
    border: none;
    border-radius: 7px;
    font-size: 0.9375rem;
    font-weight: 600;
    font-family: var(--font-body);
    cursor: pointer;
    transition: background-color 0.15s ease;
    white-space: nowrap;
  }

  .notify-btn:hover {
    background-color: var(--color-forest);
  }

  /* ——— Responsive ——— */
  @media (max-width: 640px) {
    .pricing-section,
    .notify-section,
    .faq-section,
    .cta-section { padding: 3.5rem 0; }

    .pricing-row {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

<style is:global>
  @keyframes heirly-price-shimmer {
    0%   { background-position: -200% 0; }
    100% { background-position:  200% 0; }
  }

  /* Covers the full .pricing-price-block area while the fetch is in flight */
  .price-shimmer-overlay {
    position: absolute;
    inset: 0;
    border-radius: 10px;
    background: linear-gradient(
      90deg,
      #ede8e0 0%,
      #f7f4ef 45%,
      #ede8e0 100%
    );
    background-size: 200% 100%;
    animation: heirly-price-shimmer 1.6s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
  }

  /* "Normally $X per estate" line — stacked below "during early access" */
  .pricing-normally {
    display: block;
    font-size: 0.8125rem;
    color: var(--color-slate);
    opacity: 0.55;
    margin-top: 0.375rem;
  }
</style>

<script>
  document.getElementById('notify-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const email = (form.querySelector('[name="notify_email"]') as HTMLInputElement)?.value.trim();
    if (!email) return;
    window.location.href = `mailto:hello@heirly.app?subject=Notify%20me%20when%20Heirly%20opens&body=${encodeURIComponent(email)}`;
  });

  // ——— Geo-currency pricing ———
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';

  let freePriceAmountEl: HTMLElement | null = null;
  let freePriceBlock: HTMLElement | null = null;
  let paidPriceBlock: HTMLElement | null = null;

  document.querySelectorAll<HTMLElement>('.pricing-card').forEach(card => {
    const plan = card.querySelector('.pricing-plan')?.textContent?.trim();
    if (plan === 'Free') {
      freePriceBlock = card.querySelector('.pricing-price-block');
      freePriceAmountEl = card.querySelector('.pricing-amount');
    } else if (plan === 'Full estate') {
      paidPriceBlock = card.querySelector('.pricing-price-block');
    }
  });

  // Shimmer overlay covers the full price block while loading
  function attachShimmer(block: HTMLElement): HTMLElement {
    block.style.position = 'relative';
    const overlay = document.createElement('div');
    overlay.className = 'price-shimmer-overlay';
    overlay.setAttribute('aria-hidden', 'true');
    block.appendChild(overlay);
    return overlay;
  }

  function removeShimmer(overlay: HTMLElement): void {
    overlay.style.transition = 'opacity 220ms ease';
    overlay.style.opacity = '0';
    setTimeout(() => overlay.remove(), 220);
  }

  const freeShimmer = freePriceBlock ? attachShimmer(freePriceBlock) : null;
  const paidShimmer = paidPriceBlock ? attachShimmer(paidPriceBlock) : null;

  // "Normally $X per estate" line — hidden behind shimmer until fetch resolves
  let normallyEl: HTMLElement | null = null;
  if (paidPriceBlock) {
    normallyEl = document.createElement('span');
    normallyEl.className = 'pricing-normally';
    normallyEl.style.opacity = '0';
    paidPriceBlock.appendChild(normallyEl);
  }

  function applyPricing(symbol: string, amount: number): void {
    // Update text while still hidden behind shimmer
    if (freePriceAmountEl) freePriceAmountEl.textContent = `${symbol}0`;
    if (normallyEl) normallyEl.textContent = `Normally ${symbol}${amount} per estate`;

    // Fade out shimmers — reveals updated text underneath
    if (freeShimmer) removeShimmer(freeShimmer);
    if (paidShimmer) removeShimmer(paidShimmer);

    // Fade in "Normally..." after shimmer has cleared
    if (normallyEl) {
      setTimeout(() => {
        normallyEl!.style.transition = 'opacity 220ms ease';
        normallyEl!.style.opacity = '0.55';
      }, 180);
    }
  }

  fetch('https://dmthypxyqdlihrzkipgc.supabase.co/functions/v1/get_pricing', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
    },
  })
    .then(r => (r.ok ? r.json() : Promise.reject()))
    .then((d: { symbol?: string; amount?: number }) => applyPricing(d.symbol ?? '$', d.amount ?? 99))
    .catch(() => applyPricing('$', 99));
</script>
